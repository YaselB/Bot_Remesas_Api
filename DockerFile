# Etapa 1: Compilación
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copiar los archivos .csproj (ahora están en la raíz, no dentro de src)
COPY ["BotRemesas.Presentation/BotRemesas.Presentation.csproj", "BotRemesas.Presentation/"]
COPY ["BotRemesas.Application/BotRemesas.Application.csproj", "BotRemesas.Application/"]
COPY ["BotRemesas.Domain/BotRemesas.Domain.csproj", "BotRemesas.Domain/"]
COPY ["BotRemesas.Infrastructure/BotRemesas.Infrastructure.csproj", "BotRemesas.Infrastructure/"]

RUN dotnet restore "BotRemesas.Presentation/BotRemesas.Presentation.csproj"

# Copiar todo el código fuente
COPY . .

# Publicar la API
WORKDIR "/src/BotRemesas.Presentation"
RUN dotnet publish "BotRemesas.Presentation.csproj" -c Release -o /app/publish

# Etapa 2: Runtime
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS runtime
WORKDIR /app
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "BotRemesas.Presentation.dll"]